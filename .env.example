STORAGE_ROOT=storage/dataset
MODEL_DIR=storage/model
MIN_TRAINING_PHOTOS=20
FACE_MATCH_THRESHOLD=0.4
# Minimum gap required between the top-1 and runner-up class probability.
# Below this, a match is treated as "tidak dikenali" instead of trusting a
# near-coin-flip between two students who look similar to the model.
# Biased toward rejecting more (safer for attendance: a false reject just
# asks a guru to manually verify; a false accept silently marks the wrong
# student present). See app/config.py for the full reasoning and the real
# verify_model.py data behind this value.
FACE_MATCH_MARGIN=0.15

CNN_PROJECT_DIR=../../training metode cnn
TRAIN_EPOCHS=50
# EarlyStopping / ReduceLROnPlateau patience — overrides the cnn project's
# TrainingConfig at train time, so this service owns them (no cnn re-pull
# needed). At the cnn defaults: raising them regressed the model, so kept
# known-good. More photos per student is the real accuracy lever.
EARLY_STOPPING_PATIENCE=10
REDUCE_LR_PATIENCE=4
# Kept small for small VPS deployments (e.g. 2GB RAM shared with MongoDB +
# Node backend) — raise it only if the host has memory headroom to spare.
TRAIN_BATCH_SIZE=4

# Must match FACE_SERVICE_WEBHOOK_SECRET in backend/.env exactly
BACKEND_WEBHOOK_URL=http://localhost:3000/face-recognition/training-complete
FACE_SERVICE_WEBHOOK_SECRET=change-me-webhook-secret

HOST=0.0.0.0
PORT=4001
